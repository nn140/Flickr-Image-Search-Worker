{
	"name": "worker-template",
	"description": "A template for building a React application with Vite, Hono, and Cloudflare Workers",
	"cloudflare": {
		"label": "Worker Template",
		"products": [
			"Workers"
		],
		"categories": [],
		"publish": true
	},
	"dependencies": {
		"@hono/vite-build": "^1.10.1",
		"@hono/vite-dev-server": "^0.25.1",
		"@sapphire/timestamp": "^1.0.5",
		"@vitejs/plugin-react-swc": "^4.3.0",
		"axios": "^1.13.6",
		"hono": "4.12.8",
		"honox": "^0.1.55",
		"react": "^19.2.4",
		"react-dom": "^19.2.4"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@swc/core": "^1.15.18",
		"@types/node": "^25.5.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"rimraf": "^6.1.3",
		"typescript": "5.9.3",
		"vite": "^8.0.1",
		"wrangler": "^4.75.0"
	},
	"private": true,
	"scripts": {
		"build": "tsc -b && vite build",
		"cf-typegen": "wrangler types",
		"check": "tsc && vite build && wrangler deploy --dry-run",
		"clean": "rimraf .wrangler dist",
		"deploy": "wrangler deploy",
		"dev": "vite"
	},
	"type": "module",
	"packageManager": "yarn@4.12.0"
